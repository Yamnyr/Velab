    {
      "parameters": {
        "jsCode": "const results = $items(\"GET vue kpi_critical_stations\").map(item => item.json);\n\nconst fullStations = results.filter(s => s.station_state === 'FULL');\nconst emptyStations = results.filter(s => s.station_state === 'EMPTY');\n\nfunction groupByDistrict(stations) {\n    const grouped = {};\n    stations.forEach(s => {\n        if (!grouped[s.arrondissement]) grouped[s.arrondissement] = [];\n        grouped[s.arrondissement].push(s.station_name);\n    });\n    return grouped;\n}\n\n// Message pour stations pleines\nlet fullMessage = '';\nif (fullStations.length > 0) {\n    fullMessage += '🅿️ Stations pleines (0 place disponible) :\\n';\n    const groupedFull = groupByDistrict(fullStations);\n    for (const [district, names] of Object.entries(groupedFull)) {\n        fullMessage += `• ${district} :\\n`;\n        names.forEach(name => {\n            fullMessage += `    - ${name}\\n`;\n        });\n        fullMessage += '\\n';\n    }\n}\n\n// Message pour stations vides\nlet emptyMessage = '';\nif (emptyStations.length > 0) {\n    emptyMessage += '🚲 Stations vides (0 vélo disponible) :\\n';\n    const groupedEmpty = groupByDistrict(emptyStations);\n    for (const [district, names] of Object.entries(groupedEmpty)) {\n        emptyMessage += `• ${district} :\\n`;\n        names.forEach(name => {\n            emptyMessage += `    - ${name}\\n`;\n        });\n        emptyMessage += '\\n';\n    }\n}\n\n// Limiter chaque message à 4000 caractères\nif (fullMessage.length > 4000) fullMessage = fullMessage.slice(0, 4000) + \"\\n…(message tronqué)\";\nif (emptyMessage.length > 4000) emptyMessage = emptyMessage.slice(0, 4000) + \"\\n…(message tronqué)\";\n\n// Retourner deux messages séparés pour Telegram\nconst output = [];\nif (fullMessage) output.push({ json: { text: fullMessage } });\nif (emptyMessage) output.push({ json: { text: emptyMessage } });\n\nreturn output;"
      },
