        "operation": "executeQuery",
        "query": "INSERT INTO curated.dim_station (\n    station_code,\n    station_name,\n    capacity,\n    latitude,\n    longitude,\n    arrondissement\n)\nSELECT DISTINCT\n    s.stationcode,\n    s.name,\n    s.capacity,\n    (s.coordonnees_geo->>'lat')::FLOAT,\n    (s.coordonnees_geo->>'lon')::FLOAT,\n    s.nom_arrondissement_communes\nFROM staging.velib_stations s\nWHERE s.duedate IS NOT NULL\nON CONFLICT (station_code)\nDO UPDATE SET\n    station_name = EXCLUDED.station_name,\n    capacity = EXCLUDED.capacity,\n    arrondissement = EXCLUDED.arrondissement,\n    latitude = EXCLUDED.latitude,\n    longitude = EXCLUDED.longitude,\n    last_updated = CURRENT_TIMESTAMP;",
