    {
      "parameters": {
        "jsCode": "return items.map(item => {\n  const s = item.json;\n\n  const cleanString = (value) => {\n    if (!value) return null;\n\n    return value\n      .replace(/'/g, \"''\")   // échappe apostrophes SQL\n      .replace(/’/g, \"''\")   // apostrophe typographique\n      .replace(/\\\\/g, \"\\\\\\\\\") // backslash\n      .trim();\n  };\n\n  return {\n    json: {\n      stationcode: s.stationcode,\n      name: cleanString(s.name),\n      is_installed: s.is_installed === 'OUI',\n      capacity: s.capacity || 0,\n      numdocksavailable: s.numdocksavailable || 0,\n      numbikesavailable: s.numbikesavailable || 0,\n      mechanical: s.mechanical || 0,\n      ebike: s.ebike || 0,\n      is_renting: s.is_renting === 'OUI',\n      is_returning: s.is_returning === 'OUI',\n      duedate: s.duedate ? s.duedate.replace('T',' ').replace('+00:00','') : null,\n      coordonnees_geo: s.coordonnees_geo || null,\n      arrondissement: cleanString(s.nom_arrondissement_communes)\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
